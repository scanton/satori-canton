# ─── AI Provider ──────────────────────────────────────────────────────────────
# "openrouter" for local testing (free), "anthropic" for production
AI_PROVIDER=openrouter

# OpenRouter — free model router, no credits required for 'openrouter/free'
# Get a key at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=openrouter/free

# Anthropic — for production use (optional during development)
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-6

# ─── Lead Notification Email ──────────────────────────────────────────────────
# Resend API — sends you an email when someone starts a virtual interview
# Get a free key at https://resend.com
RESEND_API_KEY=re_your-key-here
NOTIFICATION_EMAIL=your@email.com

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
